{
  "name": "guruguru",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "build": "bun scripts/build.mjs",
    "build:native": "bun scripts/build-native.mjs",
    "benchmark:import": "bun scripts/benchmark-project-import.mjs",
    "benchmark:export": "bun scripts/benchmark-project-export.mjs",
    "benchmark:websam": "bun scripts/benchmark-websam-postprocess.mjs",
    "start": "bun ./dist/server/index.js",
    "start:test": "bun run build && bun scripts/start-test.mjs",
    "dev": "bun scripts/dev-hot.mjs",
    "dev:once": "bun run build && bun run start",
    "check": "bun scripts/check.mjs",
    "typecheck": "tsc --noEmit",
    "test": "bun run build:native && bun test"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "fontkit": "^2.0.4",
    "json5": "^2.2.3",
    "jszip": "^3.10.1",
    "onnxruntime-web": "^1.27.0",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.0",
    "typescript": "^7.0.2"
  }
}
